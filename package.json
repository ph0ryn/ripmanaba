{
  "name": "ripmanaba",
  "private": true,
  "description": "CLI for accessing the manaba learning management service.",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "ripmanaba": "src/index.ts"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "format": "pnpm run lint --fix . ; oxfmt . ; eslint --fix .",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "git config core.hooksPath .githooks",
    "lint": "oxlint --type-aware --type-check",
    "precommit": "pnpm run format"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "pnpm run precommit"
    ],
    "*.{js,mjs}": [
      "pnpm run format"
    ],
    "*.{json,jsonc}": [
      "pnpm oxfmt ."
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "dependencies": {
    "cac": "^6.7.14",
    "cheerio": "catalog:",
    "playwright": "^1.57.0"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "catalog:",
    "@types/node": "^25.0.0",
    "@typescript/native-preview": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-oxlint": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "sort-package-json": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "packageManager": "pnpm@11.1.1"
}
