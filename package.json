{
  "name": "ripmanaba",
  "version": "0.1.3",
  "description": "CLI for accessing the manaba learning management service.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ph0ryn/ripmanaba.git"
  },
  "license": "MIT",
  "author": "ph0ryn",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "ripmanaba": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun src/index.ts",
    "format": "pnpm run lint --fix . ; oxfmt . ; eslint --fix .",
    "lint": "oxlint --type-aware --type-check",
    "prepack": "clean-pkg-json -r devDependencies",
    "precommit": "pnpm run format"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "pnpm run precommit"
    ],
    "*.{js,mjs}": [
      "pnpm run format"
    ],
    "*.{json,jsonc}": [
      "pnpm oxfmt ."
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "dependencies": {
    "cac": "^6.7.14",
    "cheerio": "catalog:",
    "playwright": "^1.57.0"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "catalog:",
    "@types/node": "^25.0.0",
    "@typescript/native-preview": "catalog:",
    "clean-pkg-json": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-oxlint": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "sort-package-json": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "bun": ">=1.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
